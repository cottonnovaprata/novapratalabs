generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
  TECHNICIAN
}

enum MaintenanceStatus {
  PENDENTE
  EM_PROGRESSO
  CONCLUIDO
  CANCELADO
}

enum TicketStatus {
  ABERTO
  EM_ANDAMENTO
  AGUARDANDO_PECA
  CONCLUIDO
}

enum TicketPriority {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum DocumentType {
  CERTIFICADO
  LICENCA
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  phone     String?
  department String?
  jobTitle  String?
  status    String   @default("ATIVO")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assets    Asset[]
  vaultAccessLogs VaultAccessLog[]
  documents Document[]
  tickets   Ticket[]

  @@map("users")
}

model Sector {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assets    Asset[]

  @@map("sectors")
}

model Asset {
  id              String   @id @default(cuid())
  tag             String   @unique
  name            String
  type            String
  brand           String
  model           String
  serialNumber    String?
  patrimony       String?
  ipAddress       String?
  hostname        String?
  operatingSystem String?
  status          String   @default("DISPONIVEL")
  criticality     String   @default("MEDIA")
  notes           String?
  userId          String?
  sectorId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id])
  sector       Sector?       @relation(fields: [sectorId], references: [id])
  maintenances Maintenance[]
  vaultCredentials VaultCredential[]
  documents    Document[]
  tickets      Ticket[]

  @@map("assets")
}

model Maintenance {
  id                  String            @id @default(cuid())
  assetId             String
  problem             String
  description         String?
  status              MaintenanceStatus @default(PENDENTE)
  technician          String
  cost                Float?
  startDate           DateTime          @default(now())
  endDate             DateTime?
  previousAssetStatus String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  asset Asset @relation(fields: [assetId], references: [id])

  @@map("maintenances")
}

model VaultCredential {
  id                String   @id @default(cuid())
  title             String
  username          String
  passwordEncrypted String
  type              String   @default("OTHER")
  assetId           String?
  lastUsedAt        DateTime?
  lastRotatedAt     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  asset       Asset?           @relation(fields: [assetId], references: [id])
  accessLogs  VaultAccessLog[]

  @@index([assetId])
  @@index([lastRotatedAt])
  @@unique([title, username])
  @@map("vault_credentials")
}

model VaultAccessLog {
  id           String   @id @default(cuid())
  credentialId String
  userId       String?
  action       String
  createdAt    DateTime @default(now())

  credential VaultCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  user       User?           @relation(fields: [userId], references: [id])

  @@index([credentialId])
  @@index([userId])
  @@index([createdAt])
  @@map("vault_access_logs")
}

model Supplier {
  id           String   @id @default(cuid())
  name         String
  serviceType  String
  contactName  String?
  phone        String?
  email        String?
  hasContract  Boolean  @default(false)
  contractEnd  DateTime?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  documents Document[]

  @@map("suppliers")
}

model Document {
  id             String       @id @default(cuid())
  type           DocumentType
  title          String
  holder         String
  validUntil     DateTime
  responsibleId  String?
  supplierId     String?
  assetId        String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  responsible User?     @relation(fields: [responsibleId], references: [id])
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  asset       Asset?    @relation(fields: [assetId], references: [id])

  @@index([validUntil])
  @@map("documents")
}

model Ticket {
  id             String         @id @default(cuid())
  requesterName  String
  sector         String
  category       String
  description    String
  priority       TicketPriority @default(MEDIA)
  status         TicketStatus   @default(ABERTO)
  responsibleId  String?
  assetId        String?
  solution       String?
  recurring      Boolean        @default(false)
  openedAt       DateTime       @default(now())
  closedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  responsible User?  @relation(fields: [responsibleId], references: [id])
  asset       Asset? @relation(fields: [assetId], references: [id])

  @@index([status])
  @@index([priority])
  @@map("tickets")
}

model NetworkSegment {
  id        String   @id @default(cuid())
  name      String
  gateway   String
  vlan      String   @unique
  cidr      String   @unique
  totalIps  Int      @default(254)
  status    String   @default("ONLINE")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("network_segments")
}

model Producer {
  id                String   @id @default(cuid())
  name              String
  document          String?
  stateRegistration String?
  address           String?
  phone             String?
  email             String?
  whatsapp          String?
  status            String   @default("ativo")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  farms        Farm[]
  harvestLots  HarvestLot[]

  @@map("producers")
}

model Farm {
  id          String   @id @default(cuid())
  name        String
  producerId  String
  producer    Producer @relation(fields: [producerId], references: [id], onDelete: Cascade)
  plots       Plot[]
  createdAt   DateTime @default(now())

  @@map("farms")
}

model Plot {
  id           String   @id @default(cuid())
  name         String
  areaHa       Float
  variety      String
  splitArea    Boolean  @default(false)
  notes        String?
  season       String   @default("2026")
  farmId       String
  farm         Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@map("plots")
}

model HarvestLot {
  id            String    @id @default(cuid())
  blockNumber   String?
  producerId    String
  producer      Producer  @relation(fields: [producerId], references: [id], onDelete: Cascade)
  plot          String?
  harvestDate   DateTime?
  classification String?
  bales         Int       @default(0)
  totalWeightKg Float     @default(0)
  status        String    @default("colhido")
  invoiceNumber String?
  notes         String?
  season        String    @default("2026")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("harvest_lots")
}

